{
	"schemaVersion": 1,
	"id": "performance",
	"title": { "pl": "Osiągi i wysokości", "en": "Performance and altitudes" },
	"description": {
		"pl": "Wysokość ciśnieniowa i gęstościowa oraz zasięg ślizgu - obliczenia przybliżone.",
		"en": "Pressure and density altitude and glide range - rule-of-thumb calculations."
	},
	"drills": [
		{
			"id": "pressure-altitude",
			"microSkill": "general",
			"prompt": {
				"pl": "Wysokość lotniska {elev} ft, QNH {qnh} hPa → wysokość ciśnieniowa (ft)?",
				"en": "Field elevation {elev} ft, QNH {qnh} hPa → pressure altitude (ft)?"
			},
			"inputs": [
				{ "name": "elev", "min": 0, "max": 3000, "step": 100 },
				{ "name": "qnh", "min": 985, "max": 1035, "step": 1 }
			],
			"op": { "kind": "formula", "expr": "elev + (1013 - qnh) * 27" },
			"rule": {
				"pl": "`\\mathrm{PA} = \\text{elewacja} + (1013 − \\mathrm{QNH}) × 27\\ \\mathrm{ft/hPa}`",
				"en": "`\\mathrm{PA} = \\text{elevation} + (1013 − \\mathrm{QNH}) × 27\\ \\mathrm{ft/hPa}`"
			},
			"toleranceAbs": 80,
			"timeLimitSec": 60,
			"round": 0,
			"tags": ["altimetry"]
		},
		{
			"id": "density-altitude",
			"microSkill": "general",
			"prompt": {
				"pl": "Wysokość ciśnieniowa {pa} ft, temperatura {oat} °C → wysokość gęstościowa (ft)?",
				"en": "Pressure altitude {pa} ft, temperature {oat} °C → density altitude (ft)?"
			},
			"inputs": [
				{ "name": "pa", "min": 0, "max": 8000, "step": 500 },
				{ "name": "oat", "min": -15, "max": 35, "step": 5 }
			],
			"op": { "kind": "formula", "expr": "pa + 120 * (oat - (15 - pa / 1000 * 2))" },
			"rule": {
				"pl": "`\\mathrm{DA} = \\mathrm{PA} + 120 × (\\mathrm{OAT} − \\mathrm{ISA}); \\mathrm{ISA} = 15 − 2 × \\mathrm{PA}/1000`",
				"en": "`\\mathrm{DA} = \\mathrm{PA} + 120 × (\\mathrm{OAT} − \\mathrm{ISA\\ temp}); \\mathrm{ISA} = 15 − 2 × \\mathrm{PA}/1000`"
			},
			"toleranceAbs": 150,
			"timeLimitSec": 60,
			"round": 0,
			"tags": ["performance"]
		},
		{
			"id": "glide-range",
			"microSkill": "nav_rule",
			"prompt": {
				"pl": "Wysokość {height} m, doskonałość {ld}:1 (w bezwietrznie) → zasięg ślizgu (km)?",
				"en": "Height {height} m, glide ratio {ld}:1 (still air) → glide range (km)?"
			},
			"inputs": [
				{ "name": "height", "min": 300, "max": 2000, "step": 100 },
				{ "name": "ld", "min": 20, "max": 50, "step": 1 }
			],
			"op": { "kind": "formula", "expr": "height * ld / 1000" },
			"rule": {
				"pl": "`\\text{zasięg}\\,[\\mathrm{km}] = \\text{wysokość}\\,[\\mathrm{m}] × \\text{doskonałość} ÷ 1000`",
				"en": "`\\text{range}\\,[\\mathrm{km}] = \\text{height}\\,[\\mathrm{m}] × \\text{glide ratio} ÷ 1000`"
			},
			"toleranceAbs": 1.5,
			"timeLimitSec": 60,
			"round": 0,
			"tags": ["glide"]
		},
		{
			"id": "isa-temperature",
			"microSkill": "general",
			"prompt": {
				"pl": "Temperatura ISA na wysokości {h} m (n.p.m.)?",
				"en": "ISA temperature at {h} m AMSL?"
			},
			"inputs": [{ "name": "h", "min": 0, "max": 6000, "step": 250 }],
			"op": { "kind": "formula", "expr": "15 - 6.5 * (h / 1000)" },
			"rule": {
				"pl": "`T = 15\\,°\\mathrm{C} − 6{,}5\\,°\\mathrm{C} \\text{ na każdy } 1000\\,\\mathrm{m}`",
				"en": "`T = 15\\,°\\mathrm{C} − 6.5\\,°\\mathrm{C} \\text{ per } 1000\\,\\mathrm{m}`"
			},
			"toleranceAbs": 1,
			"timeLimitSec": 60,
			"round": 1,
			"tags": ["isa"]
		}
	]
}
