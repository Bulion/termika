{
	"schemaVersion": 1,
	"id": "glider-calcs",
	"title": { "pl": "Obliczenia szybowcowe", "en": "Glider calculations" },
	"description": {
		"pl": "Współczynnik obciążenia i prędkość przeciągnięcia w zakręcie.",
		"en": "Load factor and stall speed in a turn."
	},
	"drills": [
		{
			"id": "load-factor-turn",
			"microSkill": "general",
			"prompt": {
				"pl": "Zakręt z przechyleniem {bank}° (lot poziomy) → współczynnik obciążenia n?",
				"en": "Level turn at {bank}° bank → load factor n?"
			},
			"inputs": [{ "name": "bank", "min": 0, "max": 70, "step": 5 }],
			"op": { "kind": "formula", "expr": "1 / cos(bank)" },
			"rule": {
				"pl": "`n = 1 ÷ \\cos(\\text{przechylenie})`",
				"en": "`n = 1 ÷ \\cos(\\text{bank})`"
			},
			"toleranceAbs": 0.1,
			"timeLimitSec": 60,
			"round": 2,
			"tags": ["load-factor"]
		},
		{
			"id": "stall-speed-turn",
			"microSkill": "general",
			"prompt": {
				"pl": "Vs {vs} km/h w locie poziomym → Vs w zakręcie {bank}° (km/h)?",
				"en": "Vs {vs} km/h level → stall speed in a {bank}° turn (km/h)?"
			},
			"inputs": [
				{ "name": "vs", "min": 60, "max": 90, "step": 5 },
				{ "name": "bank", "min": 0, "max": 60, "step": 10 }
			],
			"op": { "kind": "formula", "expr": "vs / sqrt(cos(bank))" },
			"rule": {
				"pl": "`V_{S(\\text{zakręt})} = V_S × \\sqrt{n} = V_S ÷ \\sqrt{\\cos(\\text{przechylenie})}`",
				"en": "`V_{S(\\text{turn})} = V_S × \\sqrt{n} = V_S ÷ \\sqrt{\\cos(\\text{bank})}`"
			},
			"toleranceAbs": 3,
			"timeLimitSec": 60,
			"round": 0,
			"tags": ["stall"]
		}
	]
}
