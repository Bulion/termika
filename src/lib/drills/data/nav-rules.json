{
	"schemaVersion": 1,
	"id": "nav-rules",
	"title": { "pl": "Reguły nawigacyjne", "en": "Navigation rules of thumb" },
	"description": {
		"pl": "Mentalne reguły kciuka: prędkość opadania i odległość rozpoczęcia zniżania.",
		"en": "Mental rules of thumb: rate of descent and top-of-descent distance."
	},
	"drills": [
		{
			"id": "rod-3deg",
			"microSkill": "nav_rule",
			"prompt": {
				"pl": "GS {value} kt, ścieżka 3° → ROD (ft/min)?",
				"en": "GS {value} kt, 3° slope → ROD (ft/min)?"
			},
			"generate": { "min": 70, "max": 160, "step": 10 },
			"op": { "kind": "linear", "factor": 5 },
			"rule": {
				"pl": "`\\mathrm{GS} ÷ 2 × 10` (czyli `\\mathrm{GS} × 5`)",
				"en": "`\\mathrm{GS} ÷ 2 × 10` (i.e. `\\mathrm{GS} × 5`)"
			},
			"tolerancePct": 5,
			"timeLimitSec": 10,
			"tags": ["descent"]
		},
		{
			"id": "tod-distance",
			"microSkill": "nav_rule",
			"prompt": {
				"pl": "{value} tys. ft do zniżenia (3°) → odległość TOD (NM)?",
				"en": "{value} thousand ft to lose (3°) → TOD distance (NM)?"
			},
			"generate": { "min": 2, "max": 12, "step": 1 },
			"op": { "kind": "linear", "factor": 3 },
			"rule": {
				"pl": "`\\text{tys. ft} × 3` (reguła 3:1)",
				"en": "`\\text{thousands ft} × 3` (3:1 rule)"
			},
			"tolerancePct": 5,
			"timeLimitSec": 10,
			"tags": ["descent"]
		},
		{
			"id": "time-speed-distance",
			"microSkill": "nav_rule",
			"prompt": {
				"pl": "{distance} NM przy {speed} kt → czas (min)?",
				"en": "{distance} NM at {speed} kt → time (min)?"
			},
			"inputs": [
				{ "name": "distance", "min": 10, "max": 120, "step": 10 },
				{ "name": "speed", "min": 60, "max": 120, "step": 10 }
			],
			"op": { "kind": "formula", "expr": "distance / speed * 60" },
			"rule": {
				"pl": "`\\text{odległość} ÷ \\mathrm{GS} × 60`",
				"en": "`\\text{distance} ÷ \\mathrm{GS} × 60`"
			},
			"tolerancePct": 5,
			"timeLimitSec": 15,
			"tags": ["time"]
		},
		{
			"id": "one-in-sixty",
			"microSkill": "nav_rule",
			"prompt": {
				"pl": "{offset} NM odchyłki po {leg} NM → błąd kursu (°)?",
				"en": "{offset} NM off track after {leg} NM → track error (°)?"
			},
			"inputs": [
				{ "name": "offset", "min": 1, "max": 10, "step": 1 },
				{ "name": "leg", "min": 30, "max": 120, "step": 10 }
			],
			"op": { "kind": "formula", "expr": "offset / leg * 60" },
			"rule": {
				"pl": "`\\text{odchyłka} ÷ \\text{przebyta odległość} × 60`",
				"en": "`\\text{offset} ÷ \\text{distance flown} × 60`"
			},
			"tolerancePct": 8,
			"timeLimitSec": 15,
			"tags": ["track"]
		},
		{
			"id": "map-distance-500k",
			"microSkill": "unit_conversion",
			"prompt": {
				"pl": "{cm} cm na mapie 1:500 000 → odległość w terenie (km)?",
				"en": "{cm} cm on a 1:500 000 chart → real distance (km)?"
			},
			"inputs": [{ "name": "cm", "min": 1, "max": 30, "step": 1 }],
			"op": { "kind": "formula", "expr": "cm * 5" },
			"rule": {
				"pl": "`1\\,\\mathrm{cm} = 5\\,\\mathrm{km}` (skala 1:500 000)",
				"en": "`1\\,\\mathrm{cm} = 5\\,\\mathrm{km}` (1:500 000 scale)"
			},
			"toleranceAbs": 0.5,
			"timeLimitSec": 12,
			"tags": ["charts"]
		}
	]
}
