{
	"schemaVersion": 1,
	"id": "fuel-mass",
	"title": { "pl": "Paliwo i masa", "en": "Fuel & mass" },
	"description": {
		"pl": "Przeliczanie objętości paliwa na masę i jednostek masy (avgas, jet, lb/kg).",
		"en": "Convert fuel volume to mass and between mass units (avgas, jet, lb/kg)."
	},
	"drills": [
		{
			"id": "avgas-l-kg",
			"microSkill": "unit_conversion",
			"prompt": { "pl": "{value} L AVGAS → kg?", "en": "{value} L AVGAS → kg?" },
			"generate": { "min": 20, "max": 200, "step": 10 },
			"op": { "kind": "linear", "factor": 0.72 },
			"rule": { "pl": "`≈ × 0{,}72` (gęstość AVGAS)", "en": "`≈ × 0.72` (AVGAS density)" },
			"tolerancePct": 5,
			"timeLimitSec": 60,
			"tags": ["fuel", "avgas"]
		},
		{
			"id": "jeta1-l-kg",
			"microSkill": "unit_conversion",
			"prompt": { "pl": "{value} L Jet A-1 → kg?", "en": "{value} L Jet A-1 → kg?" },
			"generate": { "min": 50, "max": 500, "step": 10 },
			"op": { "kind": "linear", "factor": 0.8 },
			"rule": { "pl": "`≈ × 0{,}8` (gęstość Jet A-1)", "en": "`≈ × 0.8` (Jet A-1 density)" },
			"tolerancePct": 5,
			"timeLimitSec": 60,
			"tags": ["fuel", "jet"]
		},
		{
			"id": "kg-lb",
			"microSkill": "unit_conversion",
			"prompt": { "pl": "{value} kg → lb?", "en": "{value} kg → lb?" },
			"generate": { "min": 10, "max": 300, "step": 10 },
			"op": { "kind": "linear", "factor": 2.205 },
			"rule": { "pl": "`≈ × 2{,}2`", "en": "`≈ × 2.2`" },
			"tolerancePct": 4,
			"timeLimitSec": 60,
			"tags": ["mass"]
		}
	]
}
