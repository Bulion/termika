{
	"name": "termika",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"license": "GPL-3.0-or-later",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' ; husky || true",
		"messages": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "npm run messages && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run messages && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint . && stylelint \"src/**/*.{css,svelte}\"",
		"format": "prettier --write .",
		"test:unit": "vitest run --project=server",
		"test:component": "vitest run --project=client",
		"test:e2e": "playwright test",
		"test": "npm run test:unit && npm run test:component && npm run test:e2e",
		"assemble:content": "tsx scripts/assemble-content.ts",
		"gen:e6b": "node scripts/gen-e6b-assets.mjs"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.2",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/convert-units": "^2.3.12",
		"@types/node": "^24",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"playwright": "^1.60.0",
		"postcss-html": "^1.8.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"stylelint": "^17.13.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@fontsource/atkinson-hyperlegible": "^5.2.8",
		"@fontsource/atkinson-hyperlegible-next": "^5.2.7",
		"@fontsource/fredoka": "^5.2.10",
		"@fontsource/plus-jakarta-sans": "^5.2.8",
		"@fontsource/space-mono": "^5.2.9",
		"@types/katex": "^0.16.8",
		"chart.js": "^4.5.1",
		"convert-units": "^2.3.4",
		"dexie": "^4.4.4",
		"katex": "^0.17.0",
		"ts-fsrs": "^5.4.1",
		"zod": "^4.4.3"
	}
}
